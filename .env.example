DB_HOST=your-database-host
DB_PORT=3306
DB_NAME=coursedb
DB_USER=your-database-user
DB_PASSWORD=your-database-password

# Railway MySQL also provides these automatically:
# MYSQLHOST=your-railway-mysql-host
# MYSQLPORT=3306
# MYSQLDATABASE=railway
# MYSQLUSER=root
# MYSQLPASSWORD=your-railway-password
FLASK_DEBUG=0
PORT=10000

# Protects AdminDash.html API data. Set this to a strong private value in Railway.
ADMIN_KEY=change-this-admin-key

DB_HOST=your-database-host
DB_PORT=3306
DB_NAME=coursedb
DB_USER=your-database-user
DB_PASSWORD=your-database-password

# Railway MySQL also provides these automatically:
# MYSQLHOST=your-railway-mysql-host
# MYSQLPORT=3306
# MYSQLDATABASE=railway
# MYSQLUSER=root
# MYSQLPASSWORD=your-railway-password
FLASK_DEBUG=0
PORT=10000

# Used to sign admin login sessions. Admin usernames/passwords are stored in the admins table.
ADMIN_SESSION_SECRET=change-this-long-random-admin-session-secret
